{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "skipLibCheck": true,
    "noEmitOnError": false,
    "composite": false,
    "noUnusedLocals": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": []
}
